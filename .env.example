PORT=3001
NODE_ENV=development

# Only required if Supabase still issues HS256 user tokens (legacy). New projects use RS256 + JWKS — verification needs no secret.
# Dashboard → Project Settings → API → JWT Secret (NOT the anon key).
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── JWT (legacy SQLite auth / WebSocket) ─────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_this_too_separate_secret_for_refresh_tokens
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=./data/manah.db

# ── OpenRouter (used when OPENROUTER_API_KEY is set and USE_MOCK_LLM is not true) ─
# https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Manah

# ── Qubrid (fallback if OpenRouter key is empty) ───────────────────────────────
QUBRID_API_KEY=your_qubrid_api_key_here
QUBRID_BASE_URL=https://platform.qubrid.com/v1
QUBRID_MODEL=google/gemini-2.5-flash

# true = mock only. false = OpenRouter if key set, else Qubrid.
USE_MOCK_LLM=false

# ── CORS (browser → this API). Default allows localhost:5173 and :8080 (Vite).
# Override completely: CORS_ORIGINS=http://localhost:8080,https://myapp.com
# Or add one origin: FRONTEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=
